+            f"Moderate structural variations detected ({confidence_score:.1f}% match). "
+            "While the core sequence is conserved, isolated anomalies may alter localized protein folding."
+        )
+        if hotspots:
+            hotspot_count = len(hotspots)
+            positions = []
+            for hs in hotspots[:3]:
+                if hs.end > hs.start:
+                    positions.append(f"{hs.start}-{hs.end}")
+                else:
+                    positions.append(str(hs.start))
+            pos_str = ", ".join(positions)
+            if hotspot_count > 3:
+                pos_str += f", and {hotspot_count - 3} more"
+            sentences.append(
+                f"{hotspot_count} mutation hotspot(s) identified at positions {pos_str}, "
+                "warranting further investigation of functional impact."
+            )
